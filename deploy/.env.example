# Copy to .env and fill in. Used by docker-compose.prod.yml.

# Public domain CityHall is served on (DNS must point here).
CITYHALL_DOMAIN=cityhall.example.com

# Email for Let's Encrypt registration / expiry notices.
ACME_EMAIL=admin@example.com

# Postgres password (any strong value).
DB_PASSWORD=change-me-to-a-strong-password

# Encrypts stored SMTP/OIDC secrets. Generate once and keep it stable:
#   openssl rand -base64 32
CITYHALL_SECRET_KEY=change-me-base64-32-bytes

# Copy to /etc/cityhall.env (chmod 600, owned by the cityhall user).
# Referenced by cityhall.service via EnvironmentFile.

# Bind to loopback; the reverse proxy on the same host terminates TLS.
BIND_ADDR=127.0.0.1:3000

# Where the frontend was copied.
STATIC_DIR=/opt/cityhall/web/dist

# SQLite on local disk (simplest), or point at Postgres:
#   DATABASE_URL=postgres://cityhall:password@localhost:5432/cityhall
DATABASE_URL=sqlite:///opt/cityhall/cityhall.db?mode=rwc

# Public URL, used for links in emails.
CITYHALL_BASE_URL=https://cityhall.example.com

# Encrypts stored SMTP/OIDC secrets. Generate once: openssl rand -base64 32
CITYHALL_SECRET_KEY=change-me-base64-32-bytes
